<%# frozen_string_literal: true %>
<% content_for :title, "Daily Momentum | FairPrice" %>

<div class="space-y-5">
  <%# Header row: time segment + title %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= render DailyMomentum::TimeSegmentBadgeComponent.new(
            segment: @report[:segment],
            et_time: @report[:et_time]
          ) %>
      <h1 class="text-lg font-bold text-gray-800">歐歐每日動量報告 🐱</h1>
    </div>
    <div class="text-xs text-gray-400">
      更新：<%= Time.current.in_time_zone("Taipei").strftime("%Y/%m/%d %H:%M") %> CST
    </div>
  </div>

  <%# Market stance %>
  <%= render DailyMomentum::MarketStanceComponent.new(
        vix:    @report[:vix],
        es:     @report[:es_change],
        nq:     @report[:nq_change],
        stance: @stance
      ) %>

  <%# Search bar %>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm px-5 py-4">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">🔍 查詢美股並加入觀察名單</p>
    <%= render DailyMomentum::SearchBarComponent.new %>
  </div>

  <%# Watchlist (CRUD + drag & drop) + Risk alert %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <div class="lg:col-span-2">
      <%= render DailyMomentum::WatchlistManagerComponent.new(
            items:  @watchlist_items,
            stocks: @report[:stocks]
          ) %>
    </div>
    <div>
      <%= render DailyMomentum::RiskAlertComponent.new(
            vix:          @report[:vix],
            level:        risk_level(@report[:vix]),
            earnings:     @report[:earnings],
            max_position: max_position_note(@report[:vix])
          ) %>
    </div>
  </div>

  <%# Stock news tab panel — populated on symbol click %>
  <%= render DailyMomentum::NewsTabPanelComponent.new %>

  <%# 歐歐 AI analysis panel — populated on 🐱 button click %>
  <%= render DailyMomentum::AnalysisPanelComponent.new %>

  <p class="text-xs text-gray-400 text-center pb-2">
    📌 本報告為歐歐AI基於Finnhub公開數據的分析觀點，不構成投資建議，請自行評估風險。🐾
  </p>
</div>
